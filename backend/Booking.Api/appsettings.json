{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5434;Database=booking;Username=postgres;Password=111"
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "127.0.0.1:6379,abortConnect=false,connectTimeout=1000,syncTimeout=1000",
    "InstanceName": "booking:"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://127.0.0.1:5173",
      "http://localhost:5173"
    ]
  },
  "Jwt": {
    "Issuer": "Booking.Api",
    "Audience": "Booking.Frontend",
    "Key": "booking-super-secret-development-key-12345",
    "AccessTokenLifetimeMinutes": 30,
    "RefreshTokenLifetimeDays": 14
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "YOUR_EMAIL_HERE",
    "Password": "YOUR_PASSWORD_HERE",
    "FromEmail": "YOUR_EMAIL_HERE",
    "FromName": "Clothing Store",
    "UseSsl": false
  },
  "Sms": {
    "ApiToken": "YOUR_IPROGSMS_API_TOKEN"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:5173"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} <CorrelationId:{CorrelationId}>{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Environment": "Production"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}